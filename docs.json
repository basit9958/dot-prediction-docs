{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Dot Insurance",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "theme": "maple",
  "colors": {
    "primary": "#16A34A",
    "light": "#4ADE80",
    "dark": "#22C55E"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://dotprediction.com"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/dotlabsco/dot-prediction-api"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Overview",
        "pages": ["index", "quickstart"]
      },
      {
        "group": "Guides",
        "pages": [
          "guides/authentication",
          "guides/platforms",
          "guides/pagination",
          "guides/errors"
        ]
      },
      {
        "group": "API Reference",
        "pages": [
          "api-reference/introduction",
          {
            "group": "Markets",
            "pages": [
              "api-reference/endpoint/list-markets",
              "api-reference/endpoint/get-market",
              "api-reference/endpoint/get-market-orderbook",
              "api-reference/endpoint/get-market-trades",
              "api-reference/endpoint/get-market-price-history"
            ]
          },
          {
            "group": "Analytics",
            "pages": [
              "api-reference/endpoint/trending",
              "api-reference/endpoint/categories",
              "api-reference/endpoint/stats",
              "api-reference/endpoint/whales",
              "api-reference/endpoint/concentration",
              "api-reference/endpoint/top-traders"
            ]
          },
          {
            "group": "Search",
            "pages": [
              "api-reference/endpoint/search-markets"
            ]
          },
          {
            "group": "Orders",
            "pages": [
              "api-reference/endpoint/create-order",
              "api-reference/endpoint/list-orders",
              "api-reference/endpoint/get-order",
              "api-reference/endpoint/cancel-order"
            ]
          },
          {
            "group": "Portfolio",
            "pages": [
              "api-reference/endpoint/get-user-positions",
              "api-reference/endpoint/get-user-trades",
              "api-reference/endpoint/get-user-pnl",
              "api-reference/endpoint/get-user-profile",
              "api-reference/endpoint/get-user-activity"
            ]
          },
          {
            "group": "Metrics",
            "pages": [
              "api-reference/endpoint/metrics-snapshot",
              "api-reference/endpoint/metrics-historical"
            ]
          },
          {
            "group": "Infrastructure",
            "pages": [
              "api-reference/endpoint/health",
              "api-reference/endpoint/list-platforms"
            ]
          }
        ]
      }
    ]
  },
  "api": {
    "baseUrl": "https://api.dotprediction.io",
    "auth": {
      "method": "key",
      "name": "X-API-Key"
    }
  },
  "openapi": "api-reference/openapi.json",
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/dotlabsco/dot-prediction-api"
    }
  }
}
